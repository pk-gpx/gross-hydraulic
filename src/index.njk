---
layout: base.njk
---

<!-- Navigation -->
<nav class="navbar" id="navbar">
    <div class="container nav-container">
        <a href="#" class="logo">
            <img src="/images/logo.png" alt="Gross Hydraulic" class="logo-img">
        </a>
        <button class="nav-toggle" id="navToggle" aria-label="Menu">
            <span></span>
            <span></span>
            <span></span>
        </button>
        <ul class="nav-menu" id="navMenu">
            <li><a href="#about">O firmě</a></li>
            <li><a href="#systems">Hydraulické systémy</a></li>
            <li><a href="#hoses">Hydraulické hadice</a></li>
            <li><a href="#gallery">Moje práce</a></li>
            <li><a href="#contact">Kontakt</a></li>
            <li><a href="#contact" class="btn btn-primary nav-cta">Kontaktovat</a></li>
        </ul>
    </div>
</nav>

<!-- Hero Section -->
<section class="hero" id="hero">
    <div class="hero-bg">
        <div class="hero-overlay"></div>
        <img src="{{ hero.heroImage }}" alt="{{ hero.heroImageAlt }}" class="hero-bg-img">
    </div>
    <div class="container hero-content">
        <div class="hero-text" data-animate="fade-up">
            <div class="hero-badge">
                <span class="badge-dot"></span>
                {{ hero.badge }}
            </div>
            <h1>{{ hero.headingLine1 }}<br><span class="text-yellow">{{ hero.headingLine2 }}</span></h1>
            <p class="hero-description">{{ hero.description }}</p>
            <div class="hero-actions">
                <a href="{{ hero.ctaLink }}" class="btn btn-primary btn-lg">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                    {{ hero.ctaText }}
                </a>
                <a href="#about" class="btn btn-outline btn-lg">
                    {{ hero.secondaryCtaText }}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
                </a>
            </div>
        </div>
        <div class="hero-image" data-animate="fade-left">
            <img src="{{ hero.heroImage }}" alt="{{ hero.heroImageAlt }}" class="hero-img">
        </div>
    </div>

    <!-- Brand Ticker -->
    <div class="brands-ticker">
        <div class="brands-track">
            {% for i in range(0, 4) %}
            <img src="/images/scania.png" alt="Scania" class="brand-logo">
            <img src="/images/man.png" alt="MAN" class="brand-logo">
            <img src="/images/volvo.png" alt="Volvo" class="brand-logo">
            {% endfor %}
        </div>
    </div>
</section>

<!-- About Section -->
<section class="section section-about" id="about">
    <div class="container">
        <div class="about-grid">
            <div class="about-image" data-animate="fade-right">
                <img src="{{ about.image }}" alt="{{ about.imageAlt }}" class="about-img" loading="lazy">
                <div class="image-accent"></div>
            </div>
            <div class="about-content" data-animate="fade-left">
                <span class="section-label">{{ about.label }}</span>
                <h2>{{ about.heading | safe }}</h2>
                <p class="about-text">{{ about.description }}</p>

                <div class="features-grid">
                    {% for feature in about.features %}
                    <div class="feature-card" data-animate="fade-up" data-delay="{{ loop.index * 100 }}">
                        <div class="feature-icon">
                            {% if feature.icon == "star" %}
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                            {% elif feature.icon == "clock" %}
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                            {% elif feature.icon == "document" %}
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                            {% elif feature.icon == "shield" %}
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                            {% endif %}
                        </div>
                        <h3>{{ feature.title }}</h3>
                        <p>{{ feature.description }}</p>
                    </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Hydraulic Systems Section -->
<section class="section section-services" id="systems">
    <div class="container">
        <div class="service-block">
            <div class="service-content" data-animate="fade-right">
                <span class="section-label">{{ systems.label }}</span>
                <h2>{{ systems.heading | safe }}</h2>
                <p class="service-desc">{{ systems.description }}</p>

                <ul class="service-list">
                    {% for item in systems.services %}
                    <li>
                        <div class="list-icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                        </div>
                        <div>
                            <strong>{{ item.title }}</strong> {{ item.description }}
                        </div>
                    </li>
                    {% endfor %}
                </ul>
            </div>
            <div class="service-image" data-animate="fade-left">
                <img src="{{ systems.image }}" alt="{{ systems.imageAlt }}" class="service-img" loading="lazy">
            </div>
        </div>
    </div>
</section>

<!-- Hydraulic Hoses Section -->
<section class="section section-hoses" id="hoses">
    <div class="container">
        <div class="service-block">
            <div class="service-image" data-animate="fade-right">
                <img src="{{ hoses.image }}" alt="{{ hoses.imageAlt }}" class="service-img" loading="lazy">
            </div>
            <div class="service-content" data-animate="fade-left">
                <span class="section-label">{{ hoses.label }}</span>
                <h2>{{ hoses.heading | safe }}</h2>
                <p class="service-desc">{{ hoses.description }}</p>

                <ul class="service-list">
                    {% for item in hoses.services %}
                    <li>
                        <div class="list-icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                        </div>
                        <div>
                            <strong>{{ item.title }}</strong> {{ item.description }}
                        </div>
                    </li>
                    {% endfor %}
                </ul>
                <p class="service-note">{{ hoses.note }}</p>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="section-cta" id="cta">
    <div class="container">
        <div class="cta-content" data-animate="fade-up">
            <h2>{{ cta.heading | safe }}</h2>
            <p>{{ cta.description }}</p>
            <div class="cta-actions">
                <a href="{{ site.phoneLink }}" class="btn btn-dark btn-lg">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                    {{ site.phone }}
                </a>
                <a href="mailto:{{ site.email }}" class="btn btn-outline-dark btn-lg">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                    {{ site.email }}
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Gallery Section -->
<section class="section section-gallery" id="gallery">
    <div class="container">
        <div class="section-header" data-animate="fade-up">
            <span class="section-label">{{ gallery.label }}</span>
            <h2>{{ gallery.heading | safe }}</h2>
            <p>{{ gallery.description }}</p>
        </div>
        <div class="gallery-grid" data-animate="fade-up">
            {% for item in gallery.images %}
            <div class="gallery-item">
                <img src="{{ item.image }}" alt="{{ item.alt }}" class="gallery-img" loading="lazy">
                <div class="gallery-overlay">
                    <span>Zobrazit</span>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<!-- Contact Section -->
<section class="section section-contact" id="contact">
    <div class="container">
        <div class="contact-grid">
            <div class="contact-info" data-animate="fade-right">
                <span class="section-label">{{ contact.label }}</span>
                <h2>{{ contact.heading | safe }}</h2>
                <p>{{ contact.description }}</p>

                <div class="contact-cards">
                    <a href="{{ site.phoneLink }}" class="contact-card">
                        <div class="contact-card-icon">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                        </div>
                        <div>
                            <span class="contact-card-label">Telefon</span>
                            <span class="contact-card-value">{{ site.phone }}</span>
                        </div>
                    </a>
                    <a href="mailto:{{ site.email }}" class="contact-card">
                        <div class="contact-card-icon">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                        </div>
                        <div>
                            <span class="contact-card-label">E-mail</span>
                            <span class="contact-card-value">{{ site.email }}</span>
                        </div>
                    </a>
                    <div class="contact-card">
                        <div class="contact-card-icon">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                        </div>
                        <div>
                            <span class="contact-card-label">Adresa</span>
                            <span class="contact-card-value">{{ site.address }}</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="contact-map" data-animate="fade-left">
                <iframe src="{{ site.mapsEmbed }}" class="contact-map-iframe" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
            </div>
        </div>
    </div>
</section>

<!-- Footer -->
<footer class="footer">
    <div class="container">
        <div class="footer-top">
            <div class="footer-brand">
                <a href="#" class="logo">
                    <img src="/images/logo.png" alt="Gross Hydraulic" class="logo-img logo-img-footer">
                </a>
                <p class="footer-tagline">{{ footer.tagline }}</p>
            </div>
            <div class="footer-links">
                <h4>Navigace</h4>
                <ul>
                    <li><a href="#about">O firmě</a></li>
                    <li><a href="#systems">Hydraulické systémy</a></li>
                    <li><a href="#hoses">Hydraulické hadice</a></li>
                    <li><a href="#gallery">Moje práce</a></li>
                    <li><a href="#contact">Kontakty</a></li>
                </ul>
            </div>
            <div class="footer-contact">
                <h4>Kontakt</h4>
                <ul>
                    <li>
                        <a href="{{ site.phoneLink }}" class="footer-link">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                            {{ site.phone }}
                        </a>
                    </li>
                    <li>
                        <a href="mailto:{{ site.email }}" class="footer-link">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                            {{ site.email }}
                        </a>
                    </li>
                    <li>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                        {{ site.addressStreet }}, {{ site.addressCity }}
                    </li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; {{ footer.copyright }}</p>
            <p class="footer-credit">{{ footer.credit }}</p>
        </div>
    </div>
</footer>

<!-- Lightbox -->
<div class="lightbox" id="lightbox">
    <button class="lightbox-close" aria-label="Zavřít">&times;</button>
    <img src="" alt="Náhled fotografie" id="lightboxImg">
</div>

<!-- Back to Top -->
<button class="back-to-top" id="backToTop" aria-label="Zpět nahoru">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
</button>
